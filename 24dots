# Notes:
# Top-of-form must be set to 1/2 inch via Micro Adjust before running.
# Page length must be set to 11 inches in Default Settings.
# 9.5x11 fanfold, rear push tractor, 6 LPI.

set -euo pipefail

# ----- Configuration ----------------------------------------------------------

PRINTER="${LQ590_PRINTER:-LQ590_text}"
LABEL_WIDTH=22
RULER_LINES=18
SAMPLE='ABCDEFGHIJ abcdefghij 0123456789 !@#$%^&*()'

# ----- ESC/P 2 command primitives --------------------------------------------

reset_printer() { printf '\033@'; }
lq_mode()       { printf '\033x\001'; }
draft_mode()    { printf '\033x\000'; }
ps_on()         { printf '\033p\001'; }
ps_off()        { printf '\033p\000'; }

# Pitch helpers cancel condensed mode (DC2) first, then set base pitch,
# re-applying condensed (SI) where the effective cpi requires it.
pitch_10()      { printf '\022\033P'; }
pitch_12()      { printf '\022\033M'; }
pitch_15()      { printf '\022\033g'; }
pitch_17()      { printf '\022\033P\017'; }
pitch_20()      { printf '\022\033M\017'; }

# Font selection -- case statement avoids a subshell per call.
# Each branch emits a literal octal escape that printf interprets as one byte.
font() {
    printf '\033k'
    case "$1" in
        0) printf '\000' ;;
        1) printf '\001' ;;
        2) printf '\002' ;;
        3) printf '\003' ;;
        4) printf '\004' ;;
        5) printf '\005' ;;
        6) printf '\006' ;;
        7) printf '\007' ;;
        *) return 1 ;;
    esac
}

# ----- Output helpers ---------------------------------------------------------

line() {
    printf -- '%-*s %s\r\n' "$LABEL_WIDTH" "$1" "$SAMPLE"
}

ruler_segment() {
    local padded
    printf -v padded '%5s' "$1"
    printf '....+%s' "${padded// /.}"
}

ruler() {
    local count=$1 label=$2 i
    for ((i = 1; i <= count; i++)); do ruler_segment "$i"; done
    printf '\r\n'
    for ((i = 1; i <= count; i++)); do ruler_segment 0;    done
    printf '\r\n'
    printf -- '%s\r\n' "$label"
}

ruler_10cpi() { ruler 8  "Column ruler at 10 CPI"; }
ruler_20cpi() { ruler 16 "Column ruler at 20 CPI"; }

# Print all listed pitches for one font.
# Args: font_num label pitch [pitch ...]
# Pitches: 10 12 15 17 20 ps
print_pitches() {
    local fnum=$1 label=$2
    shift 2
    local pitch
    for pitch in "$@"; do
        if [[ "$pitch" == "ps" ]]; then
            font "$fnum"; ps_on; pitch_10; line "$label PS"; ps_off
        else
            font "$fnum"; "pitch_$pitch"; line "$label $pitch cpi"
        fi
    done
}

# ----- Main -------------------------------------------------------------------

main() {
    if ! lpstat -p "$PRINTER" >/dev/null 2>&1; then
        printf 'error: CUPS queue %q not found\n' "$PRINTER" >&2
        printf '       set LQ590_PRINTER to override the default\n' >&2
        return 1
    fi

    {
        reset_printer
        lq_mode
        pitch_10

        ruler_10cpi
        pitch_20; ruler_20cpi
        pitch_10
        printf -- 'LQ-590II font and pitch sample -- 9.5x11 fanfold -- 6 LPI\r\n\r\n'

        print_pitches 0 "Roman"      10 12 15 17 20 ps
        print_pitches 1 "Sans Serif" 10 12 15 17 20 ps
        print_pitches 2 "Courier"    10 12 15 17 20 ps
        print_pitches 3 "Prestige"   10 12    17 20 ps
        print_pitches 4 "Script"     10 12    17 20 ps

        draft_mode
        print_pitches 0 "Draft"      10 12 15 17 20

        reset_printer
        lq_mode
        pitch_10
        printf -- '\r\n'
        printf -- '-- end of font samples; ruler below marks distance to perforation --\r\n'

        local i
        for ((i = 1; i <= RULER_LINES; i++)); do
            printf -- 'ruler line %02d\r\n' "$i"
        done
    } | lp -d "$PRINTER"
}

main "$@"
