PRINTER=LQ590_text

# Helper: emit ESC/P 2 commands via printf with octal escapes.
esc()       { printf '\033@'; }                    # reset
lq()        { printf '\033x\001'; }                # LQ mode
draft()     { printf '\033x\000'; }                # draft mode
font()      { printf '\033k\%03o' "$1"; }          # select font n (0-7) -- BROKEN
pitch10()   { printf '\033P'; }
pitch12()   { printf '\033M'; }
pitch15()   { printf '\033g'; }
pitch17()   { printf '\017'; }                     # SI
pitch20()   { printf '\033\017'; }
cancel_cond() { printf '\022'; }                   # DC2
ps_on()     { printf '\033p\001'; }
ps_off()    { printf '\033p\000'; }

SAMPLE='ABCDEFGHIJ abcdefghij 0123456789 !@#$%^&*()'

sample_line() {
    local label=$1
    printf -- '%-18s %s\r\n' "$label" "$SAMPLE"
}

{
    esc; lq; pitch10
    printf -- '....+....1....+....2....+....3....+....4....+....5....+....6....+....7....+....8\r\n'
    printf -- 'LQ-590II font/pitch sample\r\n\r\n'

    # Roman (font 0)
    font 0; pitch10; sample_line "Roman 10 cpi"
    font 0; pitch12; sample_line "Roman 12 cpi"
    font 0; pitch15; sample_line "Roman 15 cpi"
    font 0; pitch17; sample_line "Roman 17 cpi"; cancel_cond
    font 0; pitch20; sample_line "Roman 20 cpi"; cancel_cond
    font 0; ps_on; pitch10; sample_line "Roman PS"; ps_off

    # Sans Serif (font 1)
    font 1; pitch10; sample_line "Sans Serif 10 cpi"
    font 1; pitch12; sample_line "Sans Serif 12 cpi"
    font 1; pitch15; sample_line "Sans Serif 15 cpi"
    font 1; pitch17; sample_line "Sans Serif 17 cpi"; cancel_cond
    font 1; pitch20; sample_line "Sans Serif 20 cpi"; cancel_cond
    font 1; ps_on; pitch10; sample_line "Sans Serif PS"; ps_off

    # Courier (font 2)
    font 2; pitch10; sample_line "Courier 10 cpi"
    font 2; pitch12; sample_line "Courier 12 cpi"
    font 2; pitch15; sample_line "Courier 15 cpi"
    font 2; pitch17; sample_line "Courier 17 cpi"; cancel_cond
    font 2; pitch20; sample_line "Courier 20 cpi"; cancel_cond
    font 2; ps_on; pitch10; sample_line "Courier PS"; ps_off

    # Prestige (font 3) -- no 15 cpi
    font 3; pitch10; sample_line "Prestige 10 cpi"
    font 3; pitch12; sample_line "Prestige 12 cpi"
    font 3; pitch17; sample_line "Prestige 17 cpi"; cancel_cond
    font 3; pitch20; sample_line "Prestige 20 cpi"; cancel_cond
    font 3; ps_on; pitch10; sample_line "Prestige PS"; ps_off

    # Script (font 4) -- no 15 cpi
    font 4; pitch10; sample_line "Script 10 cpi"
    font 4; pitch12; sample_line "Script 12 cpi"
    font 4; pitch17; sample_line "Script 17 cpi"; cancel_cond
    font 4; pitch20; sample_line "Script 20 cpi"; cancel_cond
    font 4; ps_on; pitch10; sample_line "Script PS"; ps_off

    # Draft modes
    draft
    font 0; pitch10; sample_line "Draft 10 cpi"
    font 0; pitch12; sample_line "Draft 12 cpi"
    font 0; pitch15; sample_line "Draft 15 cpi"
    font 0; pitch17; sample_line "Draft 17 cpi"; cancel_cond
    font 0; pitch20; sample_line "Draft 20 cpi"; cancel_cond

    # Reset and ruler
    esc; lq; pitch10
    printf -- '\r\n-- end of font samples; lines below mark distance to perforation --\r\n'
    for i in $(seq 1 20); do
        printf -- 'line %02d of bottom-margin ruler\r\n' "$i"
    done
} | lp -d "$PRINTER"
