PRINTER=LQ590_text

# ESC/P 2 sequences as variables for clarity
ESC=$'\033'
SI=$'\017'
DC2=$'\022'

RESET="${ESC}@"
LQ_MODE="${ESC}x"$'\001'
DRAFT_MODE="${ESC}x"$'\000'

# Fonts
F_ROMAN="${ESC}k"$'\000'
F_SANS="${ESC}k"$'\001'
F_COURIER="${ESC}k"$'\002'
F_PRESTIGE="${ESC}k"$'\003'
F_SCRIPT="${ESC}k"$'\004'

# Pitches
P_10="${ESC}P"
P_12="${ESC}M"
P_15="${ESC}g"
P_17="${SI}"
P_20="${ESC}${SI}"
P_PS_ON="${ESC}p"$'\001'
P_PS_OFF="${ESC}p"$'\000'
P_CANCEL_COND="${DC2}"

SAMPLE='ABCDEFGHIJ abcdefghij 0123456789 !@#$%^&*()'

{
    printf -- '%s' "$RESET"
    printf -- '%s' "$LQ_MODE"
    printf -- '%s' "$P_10"

    printf -- '....+....1....+....2....+....3....+....4....+....5....+....6....+....7....+....8\r\n'
    printf -- 'LQ-590II font/pitch sample\r\n\r\n'

    # Roman
    printf -- '%s%s' "$F_ROMAN" "$P_10";  printf -- 'Roman      10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_12";  printf -- 'Roman      12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_15";  printf -- 'Roman      15 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_17";  printf -- 'Roman      17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_ROMAN" "$P_20";  printf -- 'Roman      20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s%s' "$F_ROMAN" "$P_PS_ON" "$P_10"; printf -- 'Roman      PS      %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_PS_OFF"

    # Sans Serif
    printf -- '%s%s' "$F_SANS" "$P_10";   printf -- 'Sans Serif 10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_SANS" "$P_12";   printf -- 'Sans Serif 12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_SANS" "$P_15";   printf -- 'Sans Serif 15 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_SANS" "$P_17";   printf -- 'Sans Serif 17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_SANS" "$P_20";   printf -- 'Sans Serif 20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s%s' "$F_SANS" "$P_PS_ON" "$P_10"; printf -- 'Sans Serif PS      %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_PS_OFF"

    # Courier
    printf -- '%s%s' "$F_COURIER" "$P_10"; printf -- 'Courier    10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_COURIER" "$P_12"; printf -- 'Courier    12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_COURIER" "$P_15"; printf -- 'Courier    15 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_COURIER" "$P_17"; printf -- 'Courier    17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_COURIER" "$P_20"; printf -- 'Courier    20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s%s' "$F_COURIER" "$P_PS_ON" "$P_10"; printf -- 'Courier    PS      %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_PS_OFF"

    # Prestige (no 15 cpi)
    printf -- '%s%s' "$F_PRESTIGE" "$P_10"; printf -- 'Prestige   10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_PRESTIGE" "$P_12"; printf -- 'Prestige   12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_PRESTIGE" "$P_17"; printf -- 'Prestige   17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_PRESTIGE" "$P_20"; printf -- 'Prestige   20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s%s' "$F_PRESTIGE" "$P_PS_ON" "$P_10"; printf -- 'Prestige   PS      %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_PS_OFF"

    # Script (no 15 cpi)
    printf -- '%s%s' "$F_SCRIPT" "$P_10"; printf -- 'Script     10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_SCRIPT" "$P_12"; printf -- 'Script     12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_SCRIPT" "$P_17"; printf -- 'Script     17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_SCRIPT" "$P_20"; printf -- 'Script     20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s%s' "$F_SCRIPT" "$P_PS_ON" "$P_10"; printf -- 'Script     PS      %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_PS_OFF"

    # Draft modes
    printf -- '%s' "$DRAFT_MODE"
    printf -- '%s%s' "$F_ROMAN" "$P_10"; printf -- 'Draft      10 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_12"; printf -- 'Draft      12 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_15"; printf -- 'Draft      15 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s%s' "$F_ROMAN" "$P_17"; printf -- 'Draft      17 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"
    printf -- '%s%s' "$F_ROMAN" "$P_20"; printf -- 'Draft      20 cpi  %s\r\n' "$SAMPLE"
    printf -- '%s' "$P_CANCEL_COND"

    # Reset and ruler for bottom-margin measurement
    printf -- '%s' "$RESET"
    printf -- '%s' "$P_10"
    printf -- '\r\n'
    printf -- '-- end of font samples; lines below mark distance to perforation --\r\n'
    for i in $(seq 1 20); do
        printf -- 'line %02d of bottom-margin ruler\r\n' "$i"
    done
} | lp -d "$PRINTER"
